rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based Access Control
    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in roles;
    }

    // Super Admin by Email or UID
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() in ["imagicityart@gmail.com", "deweshkk@gmail.com"] ||
        request.auth.uid in ["Sev825sC9HSFIBUlYN3SGIWHMss1", "8uTs7freEPaiVtywgpg5G9in4JF2"] ||
        hasRole(['super_admin'])
      );
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole(['admin', 'office_staff']);
    }

    function isAcademicAdmin() {
      return hasRole(['principal', 'office_staff']);
    }

    function isAnyAdmin() {
      return isAdmin() || isAcademicAdmin();
    }

    function isTeacher() { return hasRole(['teacher']); }
    function isStudent() { return hasRole(['student']); }
    function isParent() { return hasRole(['parent']); }
    function isAccountant() { return hasRole(['accounts']); }
    function isPrincipal() { return hasRole(['principal']); }

    function isLinkedToStudent(studentId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') == studentId ||
               studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
             );
    }

    // ===============================================================
    // Entity Validations (The Blueprints)
    // ===============================================================
    
    function isValidNotice(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.priority in ['low', 'medium', 'high'] &&
             data.targetRoles is list && data.targetRoles.size() <= 10 &&
             (data.authorId == request.auth.uid || isAdmin());
    }

    function isValidLessonLog(data) {
      return data.topic is string && data.topic.size() <= 200 &&
             data.date is string && // YYYY-MM-DD
             data.classId is string && data.subjectId is string &&
             (data.teacherId == request.auth.uid || isAdmin()) &&
             (data.get('classwork', '') == '' || data.classwork is string) &&
             (data.get('homework', '') == '' || data.homework is string);
    }

    function isValidLeave(data) {
      return data.studentId is string && data.studentId.size() <= 128 &&
             data.parentId is string && data.parentId.size() <= 128 &&
             data.studentName is string && data.studentName.size() <= 100 &&
             data.classId is string && data.classId.size() <= 20 &&
             data.leaveType in ["planned", "medical", "emergency", "half_day", "regularization"] &&
             data.status in ["submitted", "pending", "approved", "rejected", "document_required", "regularized", "unregularized", "cancelled"] &&
             data.startDate is string && data.endDate is string &&
             data.totalDays is number;
    }

    // ===============================================================
    // Collection Rules (The Fortress)
    // ===============================================================

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin()) && (
        // Prevent role escalation by non-admins
        (isSuperAdmin()) ||
        (!incoming().diff(existing()).affectedKeys().hasAny(['role', 'isAdmin']))
      );
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isAnyAdmin() && isValidNotice(incoming());
      allow update: if isAnyAdmin() && isValidNotice(incoming());
      allow delete: if isAnyAdmin();
    }

    // Academic Data
    match /classes/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /subjects/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /houses/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /timetable/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /timetableSettings/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    
    // Students
    match /students/{studentId} {
      allow get: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() || isLinkedToStudent(studentId)
      );
      allow list: if isSignedIn() && (isAnyAdmin() || isTeacher() || isAccountant());
      allow create: if isSignedIn() && (isAnyAdmin() || isAccountant());
      allow update: if isSignedIn() && (isAnyAdmin() || isAccountant() || (
        isLinkedToStudent(studentId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['fcmTokens', 'lastLogin', 'updatedAt'])
      ));
      allow delete: if isSuperAdmin();
    }

    // Teachers & Staff
    match /teachers/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /staff/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }

    // Fees & Payments
    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isAccountant();
    }
    
    match /feePayments/{paymentId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isAccountant() || isLinkedToStudent(resource.data.studentId)
      );
      allow create: if isSignedIn() && (
        isAnyAdmin() || isAccountant() || (
          isLinkedToStudent(incoming().studentId) && incoming().method == 'online'
        )
      );
      allow delete: if isSuperAdmin();
    }

    match /feeRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isAnyAdmin() || isAccountant();
      allow update: if isAnyAdmin() || isAccountant() || (
        isLinkedToStudent(existing().studentId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['paidAmount', 'status', 'updatedAt'])
      );
      allow delete: if isAnyAdmin() || isAccountant();
    }

    // Salaries & Expenses
    match /salaries/{id} { 
      allow read: if isAnyAdmin() || isAccountant(); 
      allow write: if isAdmin(); 
    }
    match /expenses/{id} { 
      allow read: if isAnyAdmin() || isAccountant(); 
      allow write: if isAdmin() || isAccountant(); 
    }

    // Role Permissions
    match /rolePermissions/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Lesson Logs (Class Diary)
    match /lessonLogs/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isTeacher() || isAnyAdmin()) && isValidLessonLog(incoming());
      allow update: if isSignedIn() && (
        isAnyAdmin() || (isTeacher() && existing().teacherId == request.auth.uid)
      ) && isValidLessonLog(incoming());
      allow delete: if isAnyAdmin();
    }

    // Study Materials
    match /studyMaterials/{id} {
      allow read: if isSignedIn();
      allow create: if isAnyAdmin() || isTeacher();
      allow update, delete: if isAnyAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }
    
    // Attendance
    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAnyAdmin() || isTeacher();
      allow delete: if isAnyAdmin();
    }

    // Student Leaves
    match /studentLeaves/{leaveId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || resource.data.parentId == request.auth.uid || isLinkedToStudent(resource.data.studentId)
      );
      allow create: if isSignedIn() && (isLinkedToStudent(incoming().studentId) || isAnyAdmin()) && isValidLeave(incoming());
      allow update: if isSignedIn() && (
        (isAnyAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'adminRemarks', 'updatedAt'])) ||
        (existing().parentId == request.auth.uid && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if isAnyAdmin();
    }
  }
}
