rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Robust check for Super Admin emails
    function isSuperAdminByEmail() {
      return isSignedIn() && 
             request.auth.token.email.lower() in ["imagicityart@gmail.com", "deweshkk@gmail.com"];
    }

    // Helper to get user data from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user document exists
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Principal: Academic/Administrative head but NO financial access per requirement
    function isAcademicAdmin() {
      return isSignedIn() && userDocExists() && getUserData().role == 'principal';
    }

    function isAdmin() {
      return isSuperAdminByEmail() || 
             (isSignedIn() && userDocExists() && 
              getUserData().role in ['super_admin', 'admin']);
    }

    // Combined Administrative access (Admin + Principal)
    function isAnyAdmin() {
      return isAdmin() || isAcademicAdmin();
    }

    function isTeacher() { return isSignedIn() && userDocExists() && getUserData().role == 'teacher'; }
    function isStudent() { return isSignedIn() && userDocExists() && getUserData().role == 'student'; }
    function isParent() { return isSignedIn() && userDocExists() && getUserData().role == 'parent'; }
    function isAccountant() { return isSignedIn() && userDocExists() && getUserData().role == 'accounts'; }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Academic Data - Generally readable by authenticated staff/students
    match /classes/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /subjects/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /houses/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /timetable/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /timetableSettings/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || 
        (userDocExists() && 
         resource.data.get('targetRoles', []).hasAny([getUserData().role]))
      );
      allow write: if isAnyAdmin();
    }

    // Students
    match /students/{studentId} {
      allow get: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() ||
        (userDocExists() && getUserData().get('studentId', '') == studentId) ||
        (userDocExists() && studentId in getUserData().get('studentIds', []))
      );
      allow list: if isAnyAdmin() || isTeacher() || isAccountant();
      allow write: if isAnyAdmin();
    }

    // Teachers
    match /teachers/{teacherId} {
      allow get: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() ||
        (userDocExists() && getUserData().get('teacherId', '') == teacherId)
      );
      allow list: if isAnyAdmin() || isTeacher() || isAccountant();
      allow write: if isAnyAdmin();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() ||
        (userDocExists() && getUserData().get('studentId', '') == resource.data.get('studentId', ''))
      );
      allow create, update: if isAnyAdmin() || isTeacher();
      allow delete: if isAnyAdmin();
    }

    // Exam Results
    match /examResults/{resultId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() ||
        (userDocExists() && getUserData().get('studentId', '') == resource.data.get('studentId', ''))
      );
      allow create, update, delete: if isAnyAdmin() || isTeacher();
    }

    // Homework
    match /homework/{homeworkId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isTeacher();
    }

    // Events, Fees
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /fees/{feeId} {
      // Principal EXCLUDED from financial data
      allow read: if isSignedIn() && (isAdmin() || isAccountant() || isParent() || isStudent());
      allow write: if isAdmin() || isAccountant();
    }
    match /feePayments/{paymentId} {
      allow read: if isSignedIn() && (isAdmin() || isAccountant());
      allow create: if isAdmin() || isAccountant();
      allow delete: if isAdmin();
    }
    match /feeRequests/{requestId} {
      allow read: if isSignedIn() && (
        isAdmin() || isAccountant() || 
        (isStudent() && userDocExists() && resource.data.studentId == getUserData().get('studentId', '')) ||
        (isParent() && userDocExists() && resource.data.studentId in getUserData().get('studentIds', []))
      );
      allow write: if isAdmin() || isAccountant();
    }

    match /activityLogs/{id} {
      allow read: if isAnyAdmin();
      allow create: if isSignedIn();
    }

    // Helper collections
    match /gradingScales/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /exams/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin() || isTeacher(); }
    match /salaries/{id} { allow read: if isAdmin() || isAccountant(); allow write: if isAdmin(); }
    match /expenses/{id} { allow read: if isAdmin() || isAccountant(); allow write: if isAdmin() || isAccountant(); }
    match /feeStructures/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /feeHeads/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
  }
}
