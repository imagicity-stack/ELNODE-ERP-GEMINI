rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based Access Control
    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in roles;
    }

    // Super Admin by Email or UID
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() in ["imagicityart@gmail.com", "deweshkk@gmail.com"] ||
        request.auth.uid in ["Sev825sC9HSFIBUlYN3SGIWHMss1", "8uTs7freEPaiVtywgpg5G9in4JF2"] ||
        hasRole(['super_admin'])
      );
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole(['admin', 'office_staff']);
    }

    function isAcademicAdmin() {
      return hasRole(['principal', 'office_staff']);
    }

    function isAnyAdmin() {
      return isAdmin() || isAcademicAdmin();
    }

    function isTeacher() { return hasRole(['teacher']); }
    function isStudent() { return hasRole(['student']); }
    function isParent() { return hasRole(['parent']); }
    function isAccountant() { return hasRole(['accounts']); }
    function isPrincipal() { return hasRole(['principal']); }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '');
    }

    function isLinkedToStudent(studentId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') == studentId ||
               studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
             );
    }

    // ===============================================================
    // Entity Validations (The Blueprints)
    // ===============================================================
    
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.name is string && data.name.size() <= 100 &&
             // Only allow these roles to be set via client during creation.
             // Higher roles must be assigned by an admin.
             data.role in ['student', 'parent'] &&
             (data.get('phone', '') == '' || data.phone.size() <= 15) &&
             (data.get('address', '') == '' || data.address.size() <= 500);
    }

    function isValidNotice(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.priority in ['low', 'medium', 'high'] &&
             data.targetRoles is list && data.targetRoles.size() <= 10 &&
             (data.authorId == request.auth.uid || isAdmin());
    }

    function isValidLessonLog(data) {
      return data.topic is string && data.topic.size() <= 200 &&
             data.date is string && // YYYY-MM-DD
             data.classId is string && data.subjectId is string &&
             (data.teacherId == request.auth.uid || isAdmin()) &&
             (data.get('classwork', '') == '' || data.classwork is string) &&
             (data.get('homework', '') == '' || data.homework is string);
    }

    function isValidLeave(data) {
      return data.studentId is string && data.studentId.size() <= 128 &&
             data.parentId == request.auth.uid && // Ensure parentId matches authenticated user
             data.studentName is string && data.studentName.size() <= 100 &&
             data.classId is string && data.classId.size() <= 20 &&
             data.leaveType in ["planned", "medical", "emergency", "half_day", "regularization"] &&
             data.status == "submitted" && // Enforce initial status
             data.startDate is string && data.endDate is string &&
             data.totalDays is number;
    }

    function isValidHomework(data) {
      return data.subjectId is string &&
             data.classId is string &&
             data.content is string && data.content.size() <= 5000 &&
             data.dueDate is string &&
             data.teacherId == request.auth.uid;
    }

    function isValidExam(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.type is string &&
             data.startDate is string && data.endDate is string;
    }

    function isValidExamResult(data) {
      return data.studentId is string &&
             data.examId is string &&
             data.percentage is number;
    }

    function isValidAttendance(data) {
      return data.studentId is string &&
             data.status in ["present", "absent", "late"] &&
             data.date is string && // YYYY-MM-DD
             data.type in ["student", "staff"];
    }

    function isValidStudyMaterial(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.fileUrl is string && data.fileUrl.size() <= 1000 &&
             data.teacherId == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules (The Fortress)
    // ===============================================================

    // Primary Academic Data (Essential for App UI)
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    
    match /houses/{houseId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    
    match /timetable/{timetableId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    
    match /timetableSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && isValidUserProfile(incoming())) || 
        isAnyAdmin()
      );
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin()) && (
        // Prevent role escalation by non-admins
        (isSuperAdmin()) ||
        (!incoming().diff(existing()).affectedKeys().hasAny(['role', 'isAdmin']))
      );
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isAnyAdmin() && isValidNotice(incoming());
      allow update: if isAnyAdmin() && isValidNotice(incoming());
      allow delete: if isAnyAdmin();
    }

    // Students
    match /students/{studentId} {
      allow get: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() || isLinkedToStudent(studentId)
      );
      allow list: if isSignedIn() && (isAnyAdmin() || isTeacher() || isAccountant());
      allow create: if isSignedIn() && (isAnyAdmin() || isAccountant());
      allow update: if isSignedIn() && (isAnyAdmin() || isAccountant() || (
        isLinkedToStudent(studentId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['fcmTokens', 'lastLogin', 'updatedAt'])
      ));
      allow delete: if isSuperAdmin();
    }

    // Teachers & Staff
    match /teachers/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAnyAdmin(); 
    }
    match /staff/{id} { 
      allow read: if isSignedIn() && (isAnyAdmin() || isAccountant() || request.auth.uid == id); 
      allow write: if isAnyAdmin() && (getUserRole() == 'super_admin'); 
    }

    // Fees & Payments
    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isAccountant();
    }
    
    match /feePayments/{paymentId} {
      allow read: if isSignedIn();
      // Online payments are written server-side via Admin SDK (bypasses rules).
      // Client-side creates are restricted to admins/accountants for manual/offline payments only.
      allow create: if isSignedIn() && (isAnyAdmin() || isAccountant()) &&
        incoming().amount is number && incoming().amount > 0 &&
        incoming().method is string;
      allow delete: if isSuperAdmin();
    }

    match /feeRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isAnyAdmin() || isAccountant();
      // paidAmount and status are updated server-side via Admin SDK for online payments.
      // Client-side updates are restricted to admins/accountants only.
      allow update: if isAnyAdmin() || isAccountant();
      allow delete: if isAnyAdmin() || isAccountant();
    }

    // Fine configuration — readable by all authenticated users (needed for fee calculations),
    // writable only by admins.
    match /fine-config/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Transient payment order records created and deleted server-side only.
    match /paymentOrders/{orderId} {
      allow read, write: if false;
    }

    // Salaries & Expenses
    match /salaries/{id} { 
      // User can read their own salary, or admins/accountants can read all
      allow read: if isAnyAdmin() || isAccountant() || (isSignedIn() && resource.data.employeeId == request.auth.uid); 
      allow write: if isAnyAdmin() && (getUserRole() in ['super_admin', 'accounts']);
    }
    match /expenses/{id} { 
      allow read: if isAnyAdmin() || isAccountant(); 
      allow write: if isAnyAdmin() && (getUserRole() in ['super_admin', 'accounts']);
    }

    // Role Permissions
    match /rolePermissions/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Lesson Logs (Class Diary)
    match /lessonLogs/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isTeacher() || isAnyAdmin()) && isValidLessonLog(incoming());
      allow update: if isSignedIn() && (
        isAnyAdmin() || (isTeacher() && existing().teacherId == request.auth.uid)
      ) && isValidLessonLog(incoming());
      allow delete: if isAnyAdmin();
    }

    // Study Materials
    match /studyMaterials/{id} {
      allow read: if isSignedIn();
      allow create: if (isAnyAdmin() || isTeacher()) && isValidStudyMaterial(incoming());
      allow update, delete: if isAnyAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }
    
    // Attendance
    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create: if (isAnyAdmin() || isTeacher()) && isValidAttendance(incoming());
      allow update: if (isAnyAdmin() || isTeacher()) && isValidAttendance(incoming());
      allow delete: if isAnyAdmin();
    }

    // Homework
    match /homework/{id} {
      allow read: if isSignedIn();
      allow create: if (isAnyAdmin() || isTeacher()) && isValidHomework(incoming());
      allow update: if (isAnyAdmin() || isTeacher()) && isValidHomework(incoming());
      allow delete: if isAnyAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }

    // Exams
    match /exams/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Exam Results
    match /examResults/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isTeacher();
    }

    // Grading Scales
    match /gradingScales/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Academic Calendar Events
    match /events/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Fee Configuration Extras
    match /feeHeads/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isAccountant();
    }

    match /feeStructures/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isAccountant();
    }

    // Admissions
    match /admission_leads/{id} {
      allow read: if isAnyAdmin();
      allow write: if isAnyAdmin();
    }

    // Student Leaves
    match /studentLeaves/{leaveId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || resource.data.parentId == request.auth.uid || isLinkedToStudent(resource.data.studentId)
      );
      allow create: if isSignedIn() && isLinkedToStudent(incoming().studentId) && isValidLeave(incoming());
      allow update: if isSignedIn() && (
        (isAnyAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'adminRemarks', 'processedBy', 'processedAt', 'updatedAt', 'attendanceConnectionStatus'])) ||
        (existing().parentId == request.auth.uid && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if isAnyAdmin() || (isSignedIn() && resource.data.parentId == request.auth.uid && resource.data.status == 'submitted');
    }

    // Activity Logs
    match /activityLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Any user can log their own activity
      allow update, delete: if false;
    }
  }
}
