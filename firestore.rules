rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Check if user document exists and has a specific role
    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in roles;
    }

    // Robust check for Super Admin emails
    function isSuperAdminByEmail() {
      return isSignedIn() && 
             request.auth.token.email in ["imagicityart@gmail.com", "deweshkk@gmail.com"];
    }

    function isAdmin() {
      return isSuperAdminByEmail() || hasRole(['super_admin', 'admin']);
    }

    function isAcademicAdmin() {
      return hasRole(['principal']);
    }

    // Combined Administrative access (Admin + Principal)
    function isAnyAdmin() {
      return isAdmin() || isAcademicAdmin();
    }

    function isTeacher() { return hasRole(['teacher']); }
    function isStudent() { return hasRole(['student']); }
    function isParent() { return hasRole(['parent']); }
    function isAccountant() { return hasRole(['accounts', 'accountant']); }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
    }

    // Academic Data - Generally readable by any authenticated user
    match /classes/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /subjects/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /houses/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /timetable/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /timetableSettings/{id} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         resource.data.get('targetRoles', []).hasAny([get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')]))
      );
      allow write: if isAnyAdmin();
    }

    // Students
    match /students/{studentId} {
      allow get: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') == studentId ||
          studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
        ))
      );
      allow list: if isSignedIn(); // Allow list so search works, but rules should restrict data
      allow write: if isAnyAdmin();
    }

    // Teachers
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() || isAccountant() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') == resource.data.get('studentId', '') || 
          resource.data.get('studentId', '') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
        ))
      );
      allow create, update: if isAnyAdmin() || isTeacher();
      allow delete: if isAnyAdmin();
    }

    // Exam Results
    match /examResults/{resultId} {
      allow read: if isSignedIn() && (
        isAnyAdmin() || isTeacher() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') == resource.data.get('studentId', '') || 
          resource.data.get('studentId', '') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
        ))
      );
      allow create, update, delete: if isAnyAdmin() || isTeacher();
    }

    // Homework
    match /homework/{homeworkId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin() || isTeacher();
    }

    // Events, Fees
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
    match /fees/{feeId} {
      allow read: if isSignedIn() && (!isAcademicAdmin());
      allow write: if isAdmin() || isAccountant();
    }
    match /feePayments/{paymentId} {
      allow read: if isSignedIn() && (
        isAdmin() || isAccountant() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          resource.data.studentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') ||
          resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
        ))
      );
      allow create: if isAdmin() || isAccountant();
      allow delete: if isAdmin();
    }
    match /feeRequests/{requestId} {
      allow read: if isSignedIn() && (
        isAdmin() || isAccountant() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          resource.data.studentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentId', '') ||
          resource.data.studentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('studentIds', [])
        ))
      );
      allow write: if isAdmin() || isAccountant();
    }

    match /activityLogs/{id} {
      allow read: if isAnyAdmin();
      allow create: if isSignedIn();
    }

    // Helper collections
    match /gradingScales/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /exams/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin() || isTeacher(); }
    match /salaries/{id} { allow read: if isAdmin() || isAccountant(); allow write: if isAdmin(); }
    match /expenses/{id} { allow read: if isAdmin() || isAccountant(); allow write: if isAdmin() || isAccountant(); }
    match /feeStructures/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }
    match /feeHeads/{id} { allow read: if isSignedIn(); allow write: if isAnyAdmin(); }

    // Safety fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
