{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and role-based access data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "name": { "type": "string", "description": "User's full name." },
        "role": { "type": "string", "enum": ["super_admin", "student", "parent", "accounts", "teacher", "principal"], "description": "User's role in the system." },
        "schoolNumber": { "type": "string", "description": "7-digit school number for students and parents." },
        "classId": { "type": "string", "description": "Reference to the class ID for students." },
        "section": { "type": "string", "description": "Section for students." },
        "parentId": { "type": "string", "description": "Reference to the parent's user ID for students." },
        "studentId": { "type": "string", "description": "Reference to the student's user ID for parents." },
        "studentIds": { "type": "array", "items": { "type": "string" }, "description": "Array of student IDs for parents." },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo." },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Detailed student information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "admissionNumber": { "type": "string" },
        "schoolNumber": { "type": "string" },
        "name": { "type": "string" },
        "classId": { "type": "string" },
        "section": { "type": "string" },
        "parentId": { "type": "string" },
        "parentDetails": {
          "type": "object",
          "properties": {
            "fatherName": { "type": "string" },
            "motherName": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "transportDetails": { "type": "string" },
        "documents": { "type": "array", "items": { "type": "string" } },
        "medicalNotes": { "type": "string" },
        "academicHistory": { "type": "string" },
        "houseId": { "type": "string" },
        "feeStatus": { "type": "string", "enum": ["paid", "pending", "overdue"] }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher profile and assignment details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "classes": { "type": "array", "items": { "type": "string" } },
        "salaryStructure": { "type": "number" },
        "joiningDetails": { "type": "string" },
        "houseInchargeId": { "type": "string" },
        "isHouseIncharge": { "type": "boolean" },
        "classTeacherOf": {
          "type": "object",
          "properties": {
            "classId": { "type": "string" },
            "section": { "type": "string" }
          }
        }
      }
    },
    "Class": {
      "title": "Class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "capacity": { "type": "number" },
              "classTeacherId": { "type": "string" }
            }
          }
        },
        "subjects": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Subject": {
      "title": "Subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["theory", "practical", "both"] },
        "teacherId": { "type": "string" }
      }
    },
    "House": {
      "title": "House",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "teacherInchargeId": { "type": "string" }
      }
    },
    "Timetable": {
      "title": "Timetable",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "periods": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time": { "type": "string" },
                    "subjectId": { "type": "string" },
                    "teacherId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "type": { "type": "string", "enum": ["student", "staff"] }
      }
    },
    "Homework": {
      "title": "Homework",
      "description": "Homework assignments and submissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "content": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "submissions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "studentId": { "type": "string" },
              "content": { "type": "string" },
              "submittedAt": { "type": "string", "format": "date-time" },
              "remarks": { "type": "string" }
            }
          }
        }
      }
    },
    "Exam": {
      "title": "Exam",
      "description": "Examination schedule and details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "term": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "classIds": { "type": "array", "items": { "type": "string" } },
        "subjectId": { "type": "string" },
        "maxMarks": { "type": "number" },
        "gradingScaleId": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "ongoing", "completed", "published"] },
        "type": { "type": "string", "enum": ["scheduled", "surprise"] },
        "topic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      }
    },
    "ExamResult": {
      "title": "Exam Result",
      "description": "Individual student results for an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "subjectResults": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subjectId": { "type": "string" },
              "marksObtained": { "type": "number" },
              "maxMarks": { "type": "number" },
              "grade": { "type": "string" },
              "remarks": { "type": "string" }
            }
          }
        },
        "totalMarks": { "type": "number" },
        "percentage": { "type": "number" },
        "overallGrade": { "type": "string" },
        "published": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GradingScale": {
      "title": "Grading Scale",
      "description": "Defines grading ranges and GPA mapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ranges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "grade": { "type": "string" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "point": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "Notice": {
      "title": "Notice",
      "description": "School-wide announcements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date" }
      }
    },
    "SchoolEvent": {
      "title": "School Event",
      "description": "Academic calendar events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["holiday", "exam", "event", "meeting"] },
        "allDay": { "type": "boolean" },
        "location": { "type": "string" },
        "color": { "type": "string" }
      }
    },
    "FeeRequest": {
      "title": "Fee Request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "academicYear": { "type": "string" },
        "month": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FeePayment": {
      "title": "Fee Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "feeRequestId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string" },
        "receiptNumber": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "biller": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["paid", "pending"] }
      }
    },
    "Salary": {
      "title": "Salary",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Detailed student information."
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher profile and assignment details."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "/homework/{homeworkId}": {
      "schema": "Homework",
      "description": "Homework assignments."
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Examination schedule."
    },
    "/examResults/{resultId}": {
      "schema": "ExamResult",
      "description": "Student exam results."
    },
    "/gradingScales/{scaleId}": {
      "schema": "GradingScale",
      "description": "Grading scale definitions."
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "School announcements."
    },
    "/events/{eventId}": {
      "schema": "SchoolEvent",
      "description": "Academic calendar events."
    },
    "/feeRequests/{requestId}": {
      "schema": "FeeRequest",
      "description": "Fee requests/invoices."
    },
    "/feePayments/{paymentId}": {
      "schema": "FeePayment",
      "description": "Fee payment records."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "School expenses."
    },
    "/salaries/{salaryId}": {
      "schema": "Salary",
      "description": "Staff salary records."
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Class information."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subject information."
    },
    "/houses/{houseId}": {
      "schema": "House",
      "description": "House information."
    },
    "/timetables/{timetableId}": {
      "schema": "Timetable",
      "description": "Timetable information."
    }
  }
}

