    teachers ||--o{ lessonLogs : "teacherId"
    teachers ||--o{ studyMaterials : "teacherId"

    classes ||--o{ exams : "classIds[]"
    subjects ||--o{ exams : "subjectId"
    gradingScales ||--o{ exams : "gradingScaleId"
